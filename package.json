{
  "name": "koers-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Koers — Nederlandse zelfhulp-cursus (ACT + VERS), 12 weken, local-first PWA",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
