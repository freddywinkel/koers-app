{
  "name": "koers-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Koers — Nederlandse zelfhulp-cursus (ACT + VERS), 12 weken, local-first PWA",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test:product": "node --test scripts/product-regression.test.mjs && node --import tsx --test scripts/product-behavior.test.ts",
    "build": "npm run typecheck && vite build",
    "build:pages": "npm run typecheck && npm run test:product && vite build --mode gh-pages",
    "preview": "vite preview",
    "icons": "python scripts/generate_icons.py",
    "audio:generate": "tsx scripts/generate-guided-audio.ts"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible": "^5.2.5",
    "@fontsource/fraunces": "^5.2.5",
    "@fontsource/nunito-sans": "^5.2.5",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "^10.5.4",
    "fake-indexeddb": "^6.2.5",
    "ffmpeg-static": "^5.2.0",
    "postcss": "^8.5.22",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "~5.6.3",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0"
  }
}
